generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  referralCode String   @unique
  referredBy   String?
  invitesSent  Int      @default(0)
  createdAt    DateTime @default(now())
}
